# Скопируйте этот файл в .env и заполните
SECRETARY_BOT_TOKEN=put-your-bot-token-here
GROQ_API_KEY=put-your-groq-key-here

# Через запятую user_id тех, кому разрешено пользоваться ботом
ALLOWED_USER_IDS=123456789

# Путь к SQLite-БД
DB_PATH=data/secretary.sqlite

# Модели Groq (https://console.groq.com/docs/models)
STT_MODEL=whisper-large-v3-turbo
LLM_MODEL=llama-3.3-70b-versatile

# По умолчанию аудио удаляется после обработки (true/false)
KEEP_AUDIO=false

# Язык распознавания по умолчанию: ru, en, auto
DEFAULT_LANG=auto

# Лимит размера аудио от Telegram (Groq API принимает до 25 МБ)
MAX_AUDIO_MB=25
